@PACKAGE_INIT@

# Set the package version
set(trtemplate_VERSION @PROJECT_VERSION@)

# Check that the requested components can be satisfied
if(NOT ${CMAKE_FIND_PACKAGE_NAME}_FIND_COMPONENTS)
    set(${CMAKE_FIND_PACKAGE_NAME}_FIND_COMPONENTS lib)
endif()

# Find all components
foreach(component ${${CMAKE_FIND_PACKAGE_NAME}_FIND_COMPONENTS})
    if(component MATCHES "lib")
        set(${CMAKE_FIND_PACKAGE_NAME}_${component}_FOUND TRUE)
    else()
        set(${CMAKE_FIND_PACKAGE_NAME}_${component}_FOUND FALSE)
    endif()
endforeach()

# Check all required components
if(${CMAKE_FIND_PACKAGE_NAME}_FIND_REQUIRED)
    foreach(component ${${CMAKE_FIND_PACKAGE_NAME}_FIND_COMPONENTS})
        if(NOT ${CMAKE_FIND_PACKAGE_NAME}_${component}_FOUND)
            set(${CMAKE_FIND_PACKAGE_NAME}_FOUND FALSE)
            return()
        endif()
    endforeach()
endif()

# Include target definitions
include("${CMAKE_CURRENT_LIST_DIR}/trtemplateTargets.cmake")

# Set the found variable
set(${CMAKE_FIND_PACKAGE_NAME}_FOUND TRUE)

# Print package information
if(NOT ${CMAKE_FIND_PACKAGE_NAME}_FIND_QUIETLY)
    message(STATUS "Found ${CMAKE_FIND_PACKAGE_NAME} ${${CMAKE_FIND_PACKAGE_NAME}_VERSION}")
    message(STATUS "  Library: ${CMAKE_CURRENT_LIST_DIR}/../lib/lib${CMAKE_FIND_PACKAGE_NAME}.so")
endif()

# Compatibility check
check_required_components(${CMAKE_FIND_PACKAGE_NAME})
